{
  "name": "la-propagande",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "shopify:setup-cms": "node scripts/shopify-setup-cms.mjs",
    "shopify:verify-cms": "node scripts/shopify-verify-cms.mjs",
    "shopify:sync-placeholders": "node scripts/shopify-sync-placeholder-media.mjs",
    "qa:check": "npm run lint && npm run typecheck && npm run test:backend && npm run build && npm run test:smoke",
    "test:backend": "node --test scripts/*.test.mjs",
    "test:smoke": "playwright test",
    "test:smoke:ui": "playwright test --ui"
  },
  "dependencies": {
    "next": "14.2.35",
    "react": "^18",
    "react-dom": "^18"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "eslint": "^8",
    "eslint-config-next": "14.2.35",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "typescript": "^5"
  }
}
